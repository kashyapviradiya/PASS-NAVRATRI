# ==========================================
# PASS NAVRATRI - ENVIRONMENT CONFIGURATION
# ==========================================

# 1. DEVELOPMENT MODE
# Set to 'true' to allow app to run with mock data if keys are missing
# Set to 'false' in production to enforce real verified payments and database
DEMO_MODE=true

# 2. FIREBASE CLIENT CONFIGURATION
# Required for frontend operations (Auth, Storage uploads)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# 3. FIREBASE ADMIN CONFIGURATION
# Required for secure server-side operations (Booking, Inventory, QR Verification)
# Note: Keep the private key secure and format with \n for line breaks
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\nHere\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=your_project_id_here

# 4. RAZORPAY CONFIGURATION
# Required for real payment processing
# Use test keys (rzp_test_...) for development
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# 5. WHATSAPP / EMAIL NOTIFICATIONS (Optional for MVP)
# MSG91_AUTH_KEY=
# SENDGRID_API_KEY=
